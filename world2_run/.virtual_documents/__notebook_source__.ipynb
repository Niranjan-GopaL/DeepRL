"""envs.py — environment registry for the generalization study.

Every environment exposes the SAME tiny interface so the PPO / sweep / metrics
code never changes:

    env = build(level_data, max_steps, **params)
    env = {reset, step, obs_of, grid, n_channels, n_actions}
      reset(level_idx)        -> (state, obs)
      step(state, action)     -> (state, obs, reward, done, info)   # info["success"]
      obs_of(...)             -> (grid, grid, n_channels)

A "level" is one procedurally generated instance; levels are pre-generated once
in numpy with a reachability check so every instance is solvable. Training samples
levels [0:n_train); evaluation uses a fixed held-out block at the end.

Two worlds are implemented:
  world1_maze    : navigate a random maze to a marked goal            (3 channels)
  world2_keydoor : fetch a key, THEN reach the door (compositional)   (5 channels)
Add a world3 by writing gen_* / build_* and a CONFIG entry, then registering it.
"""
import numpy as np
import jax, jax.numpy as jnp
from collections import deque

_MOVES = jnp.array([[-1, 0], [1, 0], [0, -1], [0, 1]], dtype=jnp.int32)  # U D L R


# ---------------------------------------------------------------- shared BFS
def _reachable(walls, a, b):
    """Is cell b reachable from cell a avoiding walls? (numpy, setup-time only)"""
    n = walls.shape[0]
    seen = np.zeros_like(walls, dtype=bool)
    q = deque([tuple(a)]); seen[a[0], a[1]] = True
    while q:
        x, y = q.popleft()
        if (x, y) == tuple(b):
            return True
        for dx, dy in ((1, 0), (-1, 0), (0, 1), (0, -1)):
            nx, ny = x + dx, y + dy
            if 0 <= nx < n and 0 <= ny < n and not walls[nx, ny] and not seen[nx, ny]:
                seen[nx, ny] = True; q.append((nx, ny))
    return False


# ============================================================ world1: maze
def gen_maze(num_levels, grid=9, p_wall=0.18, seed=0):
    rng = np.random.default_rng(seed)
    W, S, G = [], [], []
    while len(W) < num_levels:
        walls = (rng.random((grid, grid)) < p_wall).astype(np.float32)
        free = np.argwhere(walls == 0)
        if len(free) < 2:
            continue
        i = rng.choice(len(free), size=2, replace=False)
        s, g = free[i[0]], free[i[1]]
        if _reachable(walls, s, g):
            W.append(walls); S.append(s); G.append(g)
    return (jnp.asarray(np.stack(W)),
            jnp.asarray(np.stack(S)).astype(jnp.int32),
            jnp.asarray(np.stack(G)).astype(jnp.int32))

def build_maze(level_data, max_steps=80, step_pen=0.01, **_):
    walls, starts, goals = level_data
    grid = walls.shape[1]

    def obs_of(agent, level_idx):
        w = walls[level_idx]
        a = jnp.zeros((grid, grid)).at[agent[0], agent[1]].set(1.0)
        g_xy = goals[level_idx]
        g = jnp.zeros((grid, grid)).at[g_xy[0], g_xy[1]].set(1.0)
        return jnp.stack([w, a, g], axis=-1)

    def reset(level_idx):
        agent = starts[level_idx]
        return (agent, jnp.int32(0), jnp.int32(level_idx), jnp.bool_(False)), obs_of(agent, level_idx)

    def step(state, action):
        agent, t, level_idx, _ = state
        nxt = jnp.clip(agent + _MOVES[action], 0, grid - 1)
        blocked = walls[level_idx][nxt[0], nxt[1]] > 0.5
        agent2 = jnp.where(blocked, agent, nxt)
        success = jnp.all(agent2 == goals[level_idx])
        t2 = t + 1
        done = success | (t2 >= max_steps)
        reward = jnp.where(success, 1.0, 0.0) - step_pen
        return (agent2, t2, level_idx, done), obs_of(agent2, level_idx), reward, done, {"success": success}

    return dict(reset=reset, step=step, obs_of=obs_of, grid=grid, n_channels=3, n_actions=4)


# ========================================================= world2: key-door
def gen_keydoor(num_levels, grid=8, p_wall=0.12, seed=0):
    """Each level: walls, start, key, door. Guarantee start->key and key->door."""
    rng = np.random.default_rng(seed)
    W, S, K, D = [], [], [], []
    while len(W) < num_levels:
        walls = (rng.random((grid, grid)) < p_wall).astype(np.float32)
        free = np.argwhere(walls == 0)
        if len(free) < 3:
            continue
        i = rng.choice(len(free), size=3, replace=False)
        s, k, d = free[i[0]], free[i[1]], free[i[2]]
        if _reachable(walls, s, k) and _reachable(walls, k, d):
            W.append(walls); S.append(s); K.append(k); D.append(d)
    arr = lambda x: jnp.asarray(np.stack(x)).astype(jnp.int32)
    return (jnp.asarray(np.stack(W)), arr(S), arr(K), arr(D))

def build_keydoor(level_data, max_steps=110, step_pen=0.01, **_):
    walls, starts, keys, doors = level_data
    grid = walls.shape[1]

    def obs_of(agent, has_key, level_idx):
        w = walls[level_idx]
        a = jnp.zeros((grid, grid)).at[agent[0], agent[1]].set(1.0)
        k_xy, d_xy = keys[level_idx], doors[level_idx]
        # key plane vanishes once collected; door always shown; flag plane = has_key
        k = jnp.zeros((grid, grid)).at[k_xy[0], k_xy[1]].set(1.0) * (1.0 - has_key)
        d = jnp.zeros((grid, grid)).at[d_xy[0], d_xy[1]].set(1.0)
        flag = jnp.full((grid, grid), has_key.astype(jnp.float32))
        return jnp.stack([w, a, k, d, flag], axis=-1)

    def reset(level_idx):
        agent = starts[level_idx]
        state = (agent, jnp.int32(0), jnp.int32(0), jnp.int32(level_idx), jnp.bool_(False))
        return state, obs_of(agent, jnp.int32(0), level_idx)

    def step(state, action):
        agent, has_key, t, level_idx, _ = state
        nxt = jnp.clip(agent + _MOVES[action], 0, grid - 1)
        blocked = walls[level_idx][nxt[0], nxt[1]] > 0.5
        agent2 = jnp.where(blocked, agent, nxt)
        got_key = jnp.all(agent2 == keys[level_idx])
        has_key2 = jnp.maximum(has_key, got_key.astype(jnp.int32))
        at_door = jnp.all(agent2 == doors[level_idx])
        success = at_door & (has_key2 > 0)
        t2 = t + 1
        done = success | (t2 >= max_steps)
        reward = jnp.where(success, 1.0, 0.0) - step_pen
        state2 = (agent2, has_key2, t2, level_idx, done)
        return state2, obs_of(agent2, has_key2, level_idx), reward, done, {"success": success}

    return dict(reset=reset, step=step, obs_of=obs_of, grid=grid, n_channels=5, n_actions=4)


# ============================================================ per-env config
# Each env carries its OWN ppo hyperparameters and budget; the sweep / metrics /
# analysis are shared. `levels_sweep` is the set of training-level counts tried.
def _PPO(**kw):
    base = dict(gamma=0.99, gae_lambda=0.95, clip=0.2, ent_coef=0.01,
                vf_coef=0.5, lr=2.5e-3)
    base.update(kw)
    return base

CONFIGS = {
    "world1_maze": dict(
        gen=gen_maze, build=build_maze, env_params=dict(p_wall=0.18),
        full=dict(grid=9, pool=356, n_test=100, base_ntrain=64, max_steps=80,
                  ppo=_PPO(num_envs=256, num_steps=64, update_epochs=4, num_minibatches=8),
                  seeds=8, chunks=15, updates=60,
                  levels_sweep=[2, 4, 16, 64, 96, 128, 192, 256]),
        smoke=dict(grid=6, pool=32, n_test=8, base_ntrain=4, max_steps=36,
                   ppo=_PPO(num_envs=32, num_steps=12, update_epochs=2, num_minibatches=4, lr=3e-3),
                   seeds=2, chunks=3, updates=8, levels_sweep=[16]),
    ),
    "world2_keydoor": dict(
        gen=gen_keydoor, build=build_keydoor, env_params=dict(p_wall=0.12),
        full=dict(grid=8, pool=356, n_test=100, base_ntrain=64, max_steps=110,
                  ppo=_PPO(num_envs=256, num_steps=64, update_epochs=4, num_minibatches=8),
                  seeds=8, chunks=15, updates=60,
                  levels_sweep=[2, 4, 16, 64, 96, 128, 192, 256]),
        smoke=dict(grid=6, pool=32, n_test=8, base_ntrain=4, max_steps=60,
                   ppo=_PPO(num_envs=32, num_steps=16, update_epochs=2, num_minibatches=4, lr=3e-3),
                   seeds=2, chunks=3, updates=10, levels_sweep=[16]),
    ),
}


