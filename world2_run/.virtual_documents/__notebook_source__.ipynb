"""ppo.py — env-agnostic PureJaxRL-style PPO with a fast, scan-based evaluator.

Changes vs the single-env version:
  * Works against the env dict {reset, step, obs_of, grid, n_channels, n_actions}
    from envs.py, so the SAME PPO serves every world.
  * `evaluate` uses a fixed-length jax.lax.scan with masking instead of a
    per-level while_loop. A vmapped while_loop runs every lane until the LONGEST
    episode anyway, so the scan does the same work with far less overhead -> the
    main speed win. It returns BOTH per-level return and a per-level success flag
    (task completed, not merely 'return > 0'), so reward shaping never pollutes
    the success metric.
"""
import jax, jax.numpy as jnp
import numpy as np
import flax.linen as nn
import optax
from functools import partial


class ActorCritic(nn.Module):
    n_actions: int
    width: int = 1
    dropout: float = 0.0

    @nn.compact
    def __call__(self, x, training: bool = False):
        w = self.width
        x = nn.relu(nn.Conv(16 * w, (3, 3), padding="SAME")(x))
        x = nn.relu(nn.Conv(32 * w, (3, 3), padding="SAME")(x))
        x = x.reshape((x.shape[0], -1))
        h = nn.relu(nn.Dense(64 * w)(x))
        if self.dropout > 0:
            h = nn.Dropout(self.dropout, deterministic=not training)(h)
        return nn.Dense(self.n_actions)(h), nn.Dense(1)(h)[:, 0]


def log_prob(logits, a):
    return jnp.take_along_axis(jax.nn.log_softmax(logits), a[:, None], axis=-1)[:, 0]

def entropy(logits):
    p, lp = jax.nn.softmax(logits), jax.nn.log_softmax(logits)
    return -jnp.sum(p * lp, axis=-1)


def make_ppo(cfg, env):
    reset, step, obs_of = env["reset"], env["step"], env["obs_of"]
    grid, n_actions = env["grid"], env["n_actions"]
    net = ActorCritic(n_actions, width=cfg["width"], dropout=cfg["dropout"])

    NE, NS, n_train = cfg["num_envs"], cfg["num_steps"], cfg["n_train"]
    GAMMA, LAM = cfg["gamma"], cfg["gae_lambda"]
    CLIP, ENT, VF = cfg["clip"], cfg["ent_coef"], cfg["vf_coef"]
    EPOCHS, NMB = cfg["update_epochs"], cfg["num_minibatches"]
    BATCH, MB = NE * NS, (NE * NS) // cfg["num_minibatches"]
    aug = cfg["aug"]

    v_reset = jax.vmap(reset)
    v_step = jax.vmap(step)
    sample_levels = lambda key, n: jax.random.randint(key, (n,), 0, n_train)

    def augment(obs, key):
        if aug == "none":
            return obs
        C = obs.shape[-1]
        if aug == "shift":
            pad = jnp.pad(obs, ((0, 0), (1, 1), (1, 1), (0, 0)))
            ks = jax.random.randint(key, (obs.shape[0], 2), 0, 3)
            return jax.vmap(lambda o, k: jax.lax.dynamic_slice(o, (k[0], k[1], 0), (grid, grid, C)))(pad, ks)
        if aug == "cutout":
            kx = jax.random.randint(key, (obs.shape[0],), 0, grid)
            ky = jax.random.randint(key, (obs.shape[0],), 0, grid)
            xs = jnp.arange(grid)
            return jax.vmap(lambda o, cx, cy: o * (~((xs[:, None] == cx) & (xs[None, :] == cy)))[:, :, None])(obs, kx, ky)
        return obs

    def make_opt():
        chain = [optax.clip_by_global_norm(0.5)]
        if cfg["reg"] == "l2":
            chain.append(optax.add_decayed_weights(cfg["weight_decay"]))
        chain.append(optax.adam(cfg["lr"]))
        return optax.chain(*chain)
    opt = make_opt()

    def init_runner(key):
        key, kp, kd, kr = jax.random.split(key, 4)
        states, obs = v_reset(sample_levels(kr, NE))
        params = net.init({"params": kp, "dropout": kd}, obs, training=False)
        return dict(params=params, opt_state=opt.init(params), states=states, obs=obs, key=key)

    def _update(runner):
        params, opt_state = runner["params"], runner["opt_state"]
        states, obs, key = runner["states"], runner["obs"], runner["key"]

        def env_step(carry, _):
            states, obs, key = carry
            key, ka, kr = jax.random.split(key, 3)
            logits, value = net.apply(params, obs, training=False)
            actions = jax.random.categorical(ka, logits)
            lp = log_prob(logits, actions)
            states2, obs2, reward, done, _ = v_step(states, actions)
            rstates, robs = v_reset(sample_levels(kr, NE))
            states2 = jax.tree_util.tree_map(
                lambda a, b: jnp.where(done.reshape((-1,) + (1,) * (a.ndim - 1)), b, a), states2, rstates)
            obs2 = jnp.where(done[:, None, None, None], robs, obs2)
            return (states2, obs2, key), (obs, actions, lp, value, reward, done)

        (states, obs, key), traj = jax.lax.scan(env_step, (states, obs, key), None, length=NS)
        _, last_val = net.apply(params, obs, training=False)

        obs_b, act_b, lp_b, val_b, rew_b, done_b = traj
        def gae_step(carry, x):
            gae, nv = carry; val, rew, done = x
            delta = rew + GAMMA * nv * (1 - done) - val
            gae = delta + GAMMA * LAM * (1 - done) * gae
            return (gae, val), gae
        _, adv = jax.lax.scan(gae_step, (jnp.zeros(NE), last_val), (val_b, rew_b, done_b), reverse=True)
        ret_b = adv + val_b
        flat = lambda x: x.reshape((BATCH,) + x.shape[2:])
        data = dict(obs=flat(obs_b), act=flat(act_b), lp=flat(lp_b), val=flat(val_b),
                    adv=flat(adv), ret=flat(ret_b))

        def epoch(carry, _):
            params, opt_state, key = carry
            key, kperm, kaug = jax.random.split(key, 3)
            d = jax.tree_util.tree_map(lambda x: x[jax.random.permutation(kperm, BATCH)], data)
            def mb_step(carry, idx):
                params, opt_state, kaug = carry
                kaug, ka = jax.random.split(kaug)
                mb = jax.tree_util.tree_map(lambda x: jax.lax.dynamic_slice_in_dim(x, idx * MB, MB, 0), d)
                def loss_fn(params, ka):
                    o = augment(mb["obs"], ka)
                    logits, value = net.apply(params, o, training=True, rngs={"dropout": ka})
                    ratio = jnp.exp(log_prob(logits, mb["act"]) - mb["lp"])
                    A = (mb["adv"] - mb["adv"].mean()) / (mb["adv"].std() + 1e-8)
                    pg = -jnp.minimum(ratio * A, jnp.clip(ratio, 1 - CLIP, 1 + CLIP) * A).mean()
                    vcl = mb["val"] + jnp.clip(value - mb["val"], -CLIP, CLIP)
                    vl = 0.5 * jnp.maximum((value - mb["ret"]) ** 2, (vcl - mb["ret"]) ** 2).mean()
                    return pg + VF * vl - ENT * entropy(logits).mean(), None
                (loss, _), grads = jax.value_and_grad(loss_fn, has_aux=True)(params, ka)
                updates, opt_state = opt.update(grads, opt_state, params)
                return (optax.apply_updates(params, updates), opt_state, kaug), loss
            (params, opt_state, _), losses = jax.lax.scan(mb_step, (params, opt_state, kaug), jnp.arange(NMB))
            return (params, opt_state, key), losses.mean()

        (params, opt_state, key), _ = jax.lax.scan(epoch, (params, opt_state, key), None, length=EPOCHS)
        return dict(params=params, opt_state=opt_state, states=states, obs=obs, key=key), rew_b.sum(0).mean()

    @partial(jax.jit, static_argnums=(1,))
    def train_chunk(runner, n_updates):
        return jax.lax.scan(lambda r, _: _update(r), runner, None, length=n_updates)

    def evaluate(params, level_indices, max_eval_steps):
        """Greedy rollout; returns (per-level return, per-level success). Scan-based."""
        def run_level(lvl):
            state, obs = reset(lvl)
            def stepf(carry, _):
                state, obs, ret, done, succ = carry
                logits, _ = net.apply(params, obs[None], training=False)
                state2, obs2, r, d, info = step(state, jnp.argmax(logits[0]))
                active = 1.0 - done.astype(jnp.float32)
                ret = ret + r * active
                succ = succ | (info["success"] & (~done))
                return (state2, obs2, ret, done | d, succ), None
            init = (state, obs, jnp.float32(0.0), jnp.bool_(False), jnp.bool_(False))
            (_, _, ret, _, succ), _ = jax.lax.scan(stepf, init, None, length=max_eval_steps)
            return ret, succ.astype(jnp.float32)
        return jax.vmap(run_level)(level_indices)   # (rets, succs)

    return init_runner, train_chunk, evaluate


