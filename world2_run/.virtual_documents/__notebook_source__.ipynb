"""experiment.py — env-agnostic sweep + analysis (success-flag based)."""
import os, time
import numpy as np, pandas as pd
import jax, jax.numpy as jnp
import matplotlib; matplotlib.use("Agg")
import matplotlib.pyplot as plt


# --- rliable-style metrics (Agarwal et al. 2021), implemented directly ---
def iqm(x):
    v = np.sort(np.asarray(x).ravel()); n = len(v)
    lo, hi = int(0.25 * n), int(np.ceil(0.75 * n))
    return float(v[lo:hi].mean()) if hi > lo else float(v.mean())

def bootstrap_ci(x, stat=iqm, reps=2000, alpha=0.05, seed=0):
    x = np.asarray(x); rng = np.random.default_rng(seed); n = x.shape[0]
    b = [stat(x[rng.integers(0, n, n)]) for _ in range(reps)]
    return float(np.percentile(b, 100 * alpha / 2)), float(np.percentile(b, 100 * (1 - alpha / 2)))

def prob_improvement(X, Y):
    a, b = np.asarray(X).ravel(), np.asarray(Y).ravel()
    return float((a[:, None] > b[None, :]).mean() + 0.5 * (a[:, None] == b[None, :]).mean())


def build_conditions(smoke, base_ntrain, levels_sweep):
    """One-at-a-time sweep from a fixed baseline (= base_ntrain levels)."""
    base = dict(n_train=base_ntrain, aug="none", reg="none", weight_decay=0.0, dropout=0.0, width=1)
    conds = [("baseline", "baseline", "-", base)]
    if smoke:
        conds += [("levels", "n_train", str(levels_sweep[0]), {**base, "n_train": levels_sweep[0]}),
                  ("aug", "shift", "shift", {**base, "aug": "shift"}),
                  ("reg", "l2", "l2", {**base, "reg": "l2", "weight_decay": 1e-4}),
                  ("width", "width", "x2", {**base, "width": 2})]
    else:
        for nl in levels_sweep:
            conds.append(("levels", "n_train", str(nl), {**base, "n_train": nl}))
        for a in ["shift", "cutout"]:
            conds.append(("aug", "augment", a, {**base, "aug": a}))
        conds.append(("reg", "l2", "l2", {**base, "reg": "l2", "weight_decay": 1e-4}))
        conds.append(("reg", "dropout", "0.1", {**base, "dropout": 0.1}))
        conds.append(("width", "width", "x2", {**base, "width": 2}))
    return conds


def run_condition(cfg_over, env, ppo_base, test_levels, max_steps, seeds, chunks, updates):
    cfg = {**ppo_base, **cfg_over}
    init_runner, train_chunk, evaluate = make_ppo(cfg, env)
    runners = jax.vmap(init_runner)(jax.random.split(jax.random.PRNGKey(0), seeds))
    v_chunk = jax.vmap(lambda r: train_chunk(r, updates))
    n_tr_eval = min(cfg["n_train"], test_levels.shape[0])
    tr_levels = jnp.arange(n_tr_eval)
    v_eval_tr = jax.vmap(lambda p: evaluate(p, tr_levels, max_steps))     # -> (rets, succs)
    v_eval_te = jax.vmap(lambda p: evaluate(p, test_levels, max_steps))
    curve = []
    for _ in range(chunks):
        runners, _ = v_chunk(runners)
        _, te_s = v_eval_te(runners["params"])
        curve.append(np.asarray(te_s).mean(axis=1))           # test success rate per seed
    tr_r, tr_s = v_eval_tr(runners["params"])
    te_r, te_s = v_eval_te(runners["params"])
    return dict(train_ret=np.asarray(tr_r), train_succ=np.asarray(tr_s),
                test_ret=np.asarray(te_r), test_succ=np.asarray(te_s),
                te_curve=np.stack(curve, axis=1))             # (seeds, chunks)


def analyze_and_save(records, outdir, env_name, seeds):
    os.makedirs(f"{outdir}/figures", exist_ok=True)
    rows = []
    for r in records:
        for s in range(r["test_succ"].shape[0]):
            rows.append(dict(
                env=env_name, condition=r["name"], intervention=r["intervention"], setting=r["setting"], seed=s,
                final_train_return=float(r["train_ret"][s].mean()), final_test_return=float(r["test_ret"][s].mean()),
                final_train_success=float(r["train_succ"][s].mean()), final_test_success=float(r["test_succ"][s].mean()),
                gap=float(r["train_ret"][s].mean() - r["test_ret"][s].mean()),
                success_gap=float(r["train_succ"][s].mean() - r["test_succ"][s].mean()),
                sample_efficiency_auc=float(r["te_curve"][s].mean())))
    df = pd.DataFrame(rows)
    df.to_csv(f"{outdir}/aggregated.csv", index=False)

    labels = [f"{r['name']}|{r['setting']}" for r in records]
    succ = {f"{r['name']}|{r['setting']}": r["test_succ"].mean(axis=1) for r in records}   # per-seed rate
    ret  = {f"{r['name']}|{r['setting']}": r["test_ret"] for r in records}                  # seeds x levels
    succ_mean = {k: float(np.mean(v)) for k, v in succ.items()}
    succ_ci   = {k: bootstrap_ci(v, np.mean) for k, v in succ.items()}
    iqm_ret   = {k: iqm(v) for k, v in ret.items()}
    base_key  = [k for k in labels if k.startswith("baseline")][0]
    poi = {k: prob_improvement(ret[k], ret[base_key]) for k in labels if k != base_key}

    y = np.arange(len(labels))
    # success-rate figure (primary)
    c = [succ_mean[k] for k in labels]; lo = [succ_ci[k][0] for k in labels]; hi = [succ_ci[k][1] for k in labels]
    fig, ax = plt.subplots(figsize=(8, 0.45 * len(labels) + 1.6))
    ax.barh(y, c, color="#0E7C7B", alpha=0.45)
    ax.errorbar(c, y, xerr=[np.array(c) - lo, np.array(hi) - c], fmt="o", capsize=4, color="#0A5C5B")
    ax.axvline(succ_mean[base_key], ls="--", color="#B4612F", lw=1.2, label="baseline")
    ax.set_yticks(y); ax.set_yticklabels(labels); ax.invert_yaxis(); ax.set_xlim(0, 1)
    ax.set_xlabel("Fraction of held-out levels solved (mean, 95% CI)")
    ax.set_title(f"{env_name}: generalization by intervention")
    ax.legend(fontsize=8); ax.grid(axis="x", alpha=0.3); fig.tight_layout()
    fig.savefig(f"{outdir}/figures/test_success_rate.png", dpi=130); plt.close(fig)

    # learning curves (test success rate over training)
    fig, ax = plt.subplots(figsize=(7.5, 4.7))
    for r in records:
        m = r["te_curve"].mean(axis=0)
        ax.plot(np.arange(1, len(m) + 1), m, marker="o", ms=3, label=f"{r['name']}|{r['setting']}")
    ax.set_xlabel("eval point (training progress)"); ax.set_ylabel("test success rate (mean over seeds)")
    ax.set_title(f"{env_name}: success learning curves (still rising => budget too short)")
    ax.legend(fontsize=6, ncol=2); ax.grid(alpha=0.3); fig.tight_layout()
    fig.savefig(f"{outdir}/figures/learning_curves.png", dpi=130); plt.close(fig)

    # SUMMARY.md
    g = df.groupby(["condition", "setting"]).agg(
        train=("final_train_return", "mean"), test=("final_test_return", "mean"),
        solved=("final_test_success", "mean"), gap=("gap", "mean")).reset_index()
    order = sorted(labels, key=lambda k: succ_mean[k], reverse=True)
    lines = [f"# Generalization-Gap Results — `{env_name}`", "",
             f"_Generated {time.strftime('%Y-%m-%d %H:%M')} · {'SMOKE' if seeds <= 2 else 'FULL'} run · {seeds} seeds_", "",
             "**How to read this.** Every agent trains to near-optimal on its *training* levels; "
             "the question is held-out performance. `Solved` = fraction of held-out levels completed "
             "(success flag, not return>0), which does not saturate. `IQM` = interquartile mean of held-out "
             "return. `Gap` = train-test return. `P(impr)` = probability a random (seed,level) return beats baseline.", "",
             "## Ranked by held-out success rate", "",
             "| Condition | Solved | 95% CI | IQM(ret) | P(impr) |", "|---|---|---|---|---|"]
    for k in order:
        p = "—" if k == base_key else f"{poi.get(k, float('nan')):.2f}"
        lines.append(f"| {k} | {succ_mean[k]*100:.0f}% | [{succ_ci[k][0]*100:.0f}%, {succ_ci[k][1]*100:.0f}%] | {iqm_ret[k]:+.3f} | {p} |")
    lines += ["", "## Mean train / test / gap", "", "| Condition | Setting | Train | Test | Solved | Gap |",
              "|---|---|---|---|---|---|"]
    for _, r in g.iterrows():
        lines.append(f"| {r['condition']} | {r['setting']} | {r['train']:+.3f} | {r['test']:+.3f} | {r['solved']*100:.0f}% | {r['gap']:+.3f} |")
    open(f"{outdir}/SUMMARY.md", "w").write("\n".join(lines))
    return df


# ----------------------------- driver (used by the notebook main cell) -----
def run_study(ENV_NAME, SMOKE_TEST, REGISTRY, fast_conds=None):
    spec = REGISTRY[ENV_NAME]
    cfg = spec["smoke" if SMOKE_TEST else "full"]
    ppo_base = cfg["ppo"]
    outdir = f"results_{ENV_NAME}"
    os.makedirs(outdir, exist_ok=True)

    level_data = spec["gen"](cfg["pool"], grid=cfg["grid"], seed=123, **spec.get("env_params", {}))
    env = spec["build"](level_data, max_steps=cfg["max_steps"], **spec.get("env_params", {}))
    test_levels = jnp.arange(cfg["pool"] - cfg["n_test"], cfg["pool"])
    conds = build_conditions(SMOKE_TEST, cfg["base_ntrain"], cfg["levels_sweep"])
    if fast_conds:
        conds = conds[:fast_conds]

    SEEDS, CHUNKS, UPDATES = cfg["seeds"], cfg["chunks"], cfg["updates"]
    total = CHUNKS * UPDATES
    steps = total * ppo_base["num_envs"] * ppo_base["num_steps"]
    steps_str = f"{steps/1e6:.1f}M" if steps >= 1e6 else f"{steps/1e3:.0f}k"
    print("=" * 66)
    print(f"  ENV: {ENV_NAME}   |   MODE: {'SMOKE (quick test)' if SMOKE_TEST else 'FULL (real run)'}")
    print(f"  {cfg['grid']}x{cfg['grid']} grid | {cfg['pool']-cfg['n_test']}-level train pool | {cfg['n_test']} held-out test")
    print(f"  {len(conds)} conditions x {SEEDS} seeds | {CHUNKS}x{UPDATES}={total} updates (~{steps_str} steps/seed)")
    print(f"  channels={env['n_channels']}  actions={env['n_actions']}  max_steps={cfg['max_steps']}")
    try:
        import jax; print(f"  JAX devices: {jax.devices()}")
    except Exception: pass
    print("=" * 66)

    t0 = time.time(); records = []
    for i, (name, interv, setting, cfg_over) in enumerate(conds, 1):
        tc = time.time()
        rec = run_condition(cfg_over, env, ppo_base, test_levels, cfg["max_steps"], SEEDS, CHUNKS, UPDATES)
        rec.update(name=name, intervention=interv, setting=setting); records.append(rec)
        trr, ter = rec["train_ret"].mean(), rec["test_ret"].mean()
        sol = rec["test_succ"].mean()
        print(f"  [{i:2d}/{len(conds)}] {name+'|'+setting:14s}  train={trr:+.2f} test={ter:+.2f} "
              f"solved={sol*100:3.0f}%  gap={trr-ter:+.2f}  ({time.time()-tc:.0f}s)" + ("  <- generalizes" if sol > 0.05 else ""))

    print("\n  analyzing + writing figures ...")
    df = analyze_and_save(records, outdir, ENV_NAME, SEEDS)
    agg = (df.groupby(["condition", "setting"]).agg(
        solved=("final_test_success", "mean"), test=("final_test_return", "mean"), gap=("gap", "mean"))
        .reset_index().sort_values("solved", ascending=False))
    base_sol = float(df[df.condition == "baseline"]["final_test_success"].mean())
    print("\n  " + "-" * 60 + f"\n  {ENV_NAME}: RANKED BY HELD-OUT SUCCESS RATE")
    print(f"  {'condition':16s} {'solved':>7s} {'test':>8s} {'gap':>7s}   vs baseline")
    for _, r in agg.iterrows():
        d = r["solved"] - base_sol
        flag = "baseline" if r["condition"] == "baseline" else (f"+{d*100:.0f} pts" if d > 0.01 else (f"{d*100:.0f} pts" if d < -0.01 else "~same"))
        print(f"  {r['condition']+'|'+r['setting']:16s} {r['solved']*100:6.0f}% {r['test']:+8.3f} {r['gap']:+7.3f}   {flag}")
    print("  " + "-" * 60)
    print(f"\n  Wrote {outdir}/SUMMARY.md, aggregated.csv, 2 figures.  (total {time.time()-t0:.0f}s)")
    return df





# Optional hidden fast-path for quick execution checks (ignored on Kaggle):
